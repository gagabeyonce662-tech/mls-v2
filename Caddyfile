# Production Configuration for aiinfluencer.ravan.ai
staging.vsell4u.ca {
    # Automatic HTTPS with Let's Encrypt
    tls info@vsell4u.ca  # replace with your email

    # API Routes - Django Backend
    handle /api/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Host {host}
        }
    }

    # Django Admin
    handle /admin* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Host {host}
        }
    }

    # Django Static Files
    handle /static/* {
        root * /code
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Django Media Files
    handle /media/* {
        root * /code
        file_server
        header Cache-Control "public, max-age=604800"
    }

    # WebSocket support (if using Django Channels)
    handle /ws/* {
        reverse_proxy backend:8000 {
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Celery Flower (Monitoring) - Protected
    handle /flower* {
        reverse_proxy celery-flower:5555 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Django-specific endpoints
    handle /sitemap.xml {
        reverse_proxy backend:8000
    }

    handle /robots.txt {
        reverse_proxy backend:8000
    }

    handle /.well-known/* {
        reverse_proxy backend:8000
    }

    # Health check
    handle /health {
        respond "OK" 200
    }

    # Next.js Frontend - Default handler (must be last)
    handle {
        reverse_proxy frontend:3000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Host {host}

            # Support Next.js hot reload in dev (if needed)
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }
}